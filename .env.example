# MTD — Morocco Top Destinations · env example
# Pull values from ~/context-2026/agents/.env (central) or your local Vault.

# Supabase (auth gate for /admin; allowlist = mat@matsiems.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# MongoDB — Morocco data
# When MONGO_URI is set, the home page + /api/mtd/destinations read from
# mtd_destinations. When unset (or unreachable), the v2 seed in
# src/lib/mtd-v2/seed.ts is used so the cinematic UX still renders.
MONGO_URI=mongodb://localhost:27017
MONGO_DB=mtd

# S3 (image / media assets — used by /admin/s3 browser)
S3_ACCESS_KEY=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=com27
S3_UPLOAD_BASE_FOLDER=mtd/

# Optional providers (left blank for now)
TMDB_API_KEY=
YOUTUBE_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
