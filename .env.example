# MongoDB — Morocco Top Destinations
# When MONGO_URI is set, /api/mtd/destinations + home page read from the
# mtd_destinations collection. When unset (or unreachable), the v2 seed data
# in src/lib/mtd-v2/seed.ts is used as a fallback so the cinematic UX still
# renders end-to-end.
MONGO_URI=mongodb://localhost:27017
MONGO_DB=mtd
